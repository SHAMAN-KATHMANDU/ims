# =============================================================================
# deploy/dev/.env.example
# Environment variables for the DEV/STAGE EC2 instance.
#
# Copy to .env and fill in real values (run ./setup.sh to be guided):
#   cp .env.example .env && nano .env
#
# Source of truth for API env vars: apps/api/src/config/env.ts
# CORS_ORIGIN and API_PUBLIC_URL are REQUIRED -- API exits on startup if missing.
#
# EC2 runtime auth policy:
# - Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY on server .env.
# - App and backup scripts use IAM instance profile credentials via IMDS.
# - Static AWS keys are local-dev-only fallback (outside server .env).
#
# S3 offsite backup (optional — ./setup-backups.sh / ./backup-s3.sh only; not read by the API):
#   BACKUPS_BUCKET=ims-shaman-backups
#   AWS_DEFAULT_REGION=ap-south-1
# =============================================================================

# =============================================================================
# PostgreSQL (used by docker-compose to init the database container)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=ims

# =============================================================================
# API -- Core (required)
# =============================================================================
NODE_ENV=staging

# Prisma database connection -- host must be the docker service name
DATABASE_URL=postgresql://postgres:change-me-secure-password@dev_db:5432/ims

JWT_SECRET=change-me-at-least-32-chars-long-secret
PORT=4000
HOST=0.0.0.0

# REQUIRED in staging/production -- API exits immediately if empty
# Must match the web app's public domain so the browser can make cross-origin requests
CORS_ORIGIN=https://stage-ims.shamankathmandu.com

# REQUIRED in staging/production -- used for Swagger docs and building public media URLs
# (e.g. Facebook Messenger outbound image/video links that Meta downloads from your server)
API_PUBLIC_URL=https://stage-api.shamankathmandu.com/api/v1

# =============================================================================
# Tenant Websites (TENANT_WEBSITES feature flag)
# Required ONLY when the websites compose profile is active (Caddy + tenant-site).
# Generate both with: openssl rand -hex 32
# =============================================================================
# Shared secret the Caddy on_demand_tls ask hook and tenant-site renderer use
# to talk to /api/v1/internal/* on the API. Min 32 chars. Keep secret.
INTERNAL_API_TOKEN=

# Shared secret the API uses to call tenant-site's /api/revalidate endpoint
# after publish/update/template-pick mutations. Keep secret.
REVALIDATE_SECRET=

# Internal URL the API uses to POST revalidation requests to tenant-site.
# Leave as default unless you move tenant-site out of the ims-dev network.
TENANT_SITE_INTERNAL_URL=http://dev_tenant_site:3100

# Public base URL for the site-editor preview iframe. Used when a tenant has
# no verified primary website domain (the common case in dev/staging) — the
# /site-layouts/:scope/preview-url endpoint mints links against this host.
# Must point at a hostname Caddy routes to dev_tenant_site (see Caddyfile).
TENANT_SITE_PUBLIC_URL=https://stage-preview.shamankathmandu.com

# HMAC secret for short-lived site preview tokens. Generate: openssl rand -hex 32
# Required when the site-editor is in use; without it preview-url returns 503.
PREVIEW_TOKEN_SECRET=

# =============================================================================
# S3 Photos (required for object storage at runtime)
# Keep these non-secret values only. Credentials come from EC2 IAM role via IMDS.
# =============================================================================
AWS_REGION=ap-south-1
PHOTOS_S3_BUCKET=ims-shaman-photos
PHOTOS_PUBLIC_URL_PREFIX=https://ims-shaman-photos.s3.ap-south-1.amazonaws.com/
PHOTOS_S3_KEY_PREFIX=dev/

# =============================================================================
# Redis (required -- BullMQ inbound/outbound/status queues + Socket.IO adapter)
# =============================================================================
REDIS_URL=redis://dev_redis:6379

# =============================================================================
# Facebook Messenger Integration
# Required to receive and send Messenger messages.
# META_APP_SECRET is used to verify webhook POST signatures (X-Hub-Signature-256).
# Leave empty to disable Messenger -- the app will start but warn at startup.
# =============================================================================
META_APP_ID=
META_APP_SECRET=

# =============================================================================
# AI messaging auto-replies (Google Gemini by default — key from Google AI Studio)
# Without AI_REPLY_API_KEY, auto-reply is skipped (logged only). Server-side only.
# =============================================================================
AI_REPLY_PROVIDER=GEMINI_API
AI_REPLY_API_KEY=
AI_REPLY_MODEL=gemini-2.5-flash
# AI_REPLY_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# AI_REPLY_ENABLED_DEFAULT=false
# BRAINTRUST_API_KEY=
# BRAINTRUST_PROJECT_NAME=IMS AI Replies

# =============================================================================
# Credential Encryption
# AES-256-GCM key for encrypting stored channel credentials (access tokens, etc.)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================
CREDENTIAL_ENCRYPTION_KEY=

# =============================================================================
# S3 tenant media (REQUIRED when NODE_ENV is not development)
# API exits on startup if these are missing in staging/production.
# EC2: prefer an instance role with s3:PutObject/GetObject on the bucket; keys optional.
# =============================================================================
AWS_REGION=ap-south-1
PHOTOS_S3_BUCKET=ims-shaman-photos
PHOTOS_PUBLIC_URL_PREFIX=https://ims-shaman-photos.s3.ap-south-1.amazonaws.com/
PHOTOS_S3_KEY_PREFIX=stage
# PHOTOS_PUBLIC_URL_ALIASES=https://d111111abcdef8.cloudfront.net/
# PHOTOS_S3_VERIFY_ON_STARTUP=1
# PHOTOS_ALLOW_LEGACY_KEYS=0
# PHOTOS_ENFORCE_CONTENT_SNIFF=0

# =============================================================================
# Feature Flags / App Environment (optional)
# APP_ENV overrides the logical environment for feature gating (default: NODE_ENV).
# FEATURE_FLAGS is a comma-separated list of flags to force-enable/disable.
# Frontend NEXT_PUBLIC_* env vars are build-time inputs for the web image, not
# runtime values read from this server .env. Set NEXT_PUBLIC_APP_ENV=staging
# and any optional NEXT_PUBLIC_FEATURE_FLAGS in the GitHub DEV_UI variable.
# =============================================================================
# APP_ENV=staging
# FEATURE_FLAGS=

# =============================================================================
# Observability -- OpenTelemetry (optional)
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable distributed tracing (Jaeger, etc.)
# =============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTEL_SERVICE_NAME=ims-api

# =============================================================================
# Database Seed — required for ./seed.sh (interactive orchestration)
# The script always seeds plan limits + platform admin, then prompts for
# test1/test2, ruby, demo, and optional minimal tenants. It does NOT read
# SEED_MODE / SEED_PROFILE / SEED_TENANTS from .env for behavior.
#
# Local legacy seed (pnpm prisma:seed without deploy script): see apps/api/prisma/seed.ts
# =============================================================================
SEED_PLATFORM_ADMIN_USERNAME=platform
SEED_PLATFORM_ADMIN_PASSWORD=change-me-admin-password
# Optional default when minimal tenant list omits per-tenant :password (script passes this)
SEED_TENANT_PASSWORD=ChangeMe123!
