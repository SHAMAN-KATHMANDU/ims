# =============================================================================
# deploy/prod/.env.example
# Environment variables for the PRODUCTION EC2 instance.
#
# Copy to .env and fill in real values (run ./setup.sh to be guided):
#   cp .env.example .env && nano .env
#
# Source of truth for API env vars: apps/api/src/config/env.ts
# CORS_ORIGIN and API_PUBLIC_URL are REQUIRED -- API exits on startup if missing.
#
# Before first run, create the backup directory on the host:
#   mkdir -p /home/ubuntu/backups
#
# S3 offsite backup (optional — ./setup-backups.sh / ./backup-s3.sh only; not read by the API):
#   BACKUPS_BUCKET=ims-shaman-backups
#   AWS_DEFAULT_REGION=ap-south-1
# =============================================================================

# =============================================================================
# PostgreSQL (used by docker-compose to init the database container)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=STRONG-RANDOM-PASSWORD-HERE
POSTGRES_DB=ims

# =============================================================================
# API -- Core (required)
# =============================================================================
NODE_ENV=production

# Prisma database connection -- host must be the docker service name
DATABASE_URL=postgresql://postgres:STRONG-RANDOM-PASSWORD-HERE@prod_db:5432/ims

JWT_SECRET=STRONG-RANDOM-SECRET-AT-LEAST-64-CHARS-LONG
PORT=4000
HOST=0.0.0.0

# REQUIRED in production -- API exits immediately if empty
# Must match the web app's public domain so the browser can make cross-origin requests
CORS_ORIGIN=https://app.shamanyantra.com

# REQUIRED in production -- used for Swagger docs and building public media URLs
# (e.g. Facebook Messenger outbound image/video links that Meta downloads from your server)
API_PUBLIC_URL=https://api.shamanyantra.com/api/v1

# =============================================================================
# Redis (required -- BullMQ inbound/outbound/status queues + Socket.IO adapter)
# =============================================================================
REDIS_URL=redis://prod_redis:6379

# =============================================================================
# Facebook Messenger Integration
# Required to receive and send Messenger messages.
# META_APP_SECRET is used to verify webhook POST signatures (X-Hub-Signature-256).
# Configure in Meta App Dashboard:
#   Webhook URL:   https://api.shamanyantra.com/api/v1/webhooks/messenger
#   Verify Token:  (per-channel token stored in DB -- see messaging channel setup)
# =============================================================================
META_APP_ID=
META_APP_SECRET=

# =============================================================================
# AI messaging auto-replies (Google Gemini by default — key from Google AI Studio)
# Without AI_REPLY_API_KEY, auto-reply is skipped (logged only). Server-side only.
# =============================================================================
AI_REPLY_PROVIDER=GEMINI_API
AI_REPLY_API_KEY=
AI_REPLY_MODEL=gemini-2.5-flash
# AI_REPLY_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# AI_REPLY_ENABLED_DEFAULT=false
# BRAINTRUST_API_KEY=
# BRAINTRUST_PROJECT_NAME=IMS AI Replies

# =============================================================================
# Credential Encryption (REQUIRED in production)
# AES-256-GCM key for encrypting stored channel credentials (access tokens, etc.)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================
CREDENTIAL_ENCRYPTION_KEY=GENERATE-WITH-COMMAND-ABOVE

# =============================================================================
# S3 tenant media (REQUIRED in production — NODE_ENV=production)
# API exits on startup if AWS_REGION, bucket, prefix, or key prefix tier is invalid.
# EC2: prefer an instance role with s3:PutObject/GetObject on the bucket.
# =============================================================================
AWS_REGION=ap-south-1
PHOTOS_S3_BUCKET=ims-shaman-photos
PHOTOS_PUBLIC_URL_PREFIX=https://ims-shaman-photos.s3.ap-south-1.amazonaws.com/
PHOTOS_S3_KEY_PREFIX=prod
# PHOTOS_PUBLIC_URL_ALIASES=https://d111111abcdef8.cloudfront.net/
# PHOTOS_S3_VERIFY_ON_STARTUP=1
# PHOTOS_ALLOW_LEGACY_KEYS=0
# PHOTOS_ENFORCE_CONTENT_SNIFF=0

# =============================================================================
# Tenant Websites (TENANT_WEBSITES feature flag)
# Required ONLY when the websites compose profile is active (Caddy + tenant-site).
# Generate both with: openssl rand -hex 32
# =============================================================================
INTERNAL_API_TOKEN=
REVALIDATE_SECRET=
# Internal URL the API uses to POST revalidation requests to tenant-site.
# Leave as default unless you move tenant-site out of the ims-prod network.
TENANT_SITE_INTERNAL_URL=http://prod_tenant_site:3100

# Public base URL fallback for site-editor preview iframes when a tenant has
# no verified primary website domain. In prod this is rarely used (tenants
# self-onboard their custom domain); set it if you want previews to work for
# tenants whose domain is still being verified. Must be a hostname Caddy
# routes to prod_tenant_site.
# TENANT_SITE_PUBLIC_URL=

# HMAC secret for short-lived site preview tokens. Required for the editor
# preview iframe; without it /site-layouts/:scope/preview-url returns 503.
PREVIEW_TOKEN_SECRET=

# =============================================================================
# Feature Flags / App Environment (optional)
# APP_ENV overrides the logical environment for feature gating (default: NODE_ENV).
# FEATURE_FLAGS is a comma-separated list of flags to force-enable/disable.
# Frontend NEXT_PUBLIC_* env vars are build-time inputs for the web image, not
# runtime values read from this server .env. Set NEXT_PUBLIC_APP_ENV=production
# and any optional NEXT_PUBLIC_FEATURE_FLAGS in the GitHub PROD_UI variable.
# =============================================================================
# APP_ENV=production
# FEATURE_FLAGS=

# =============================================================================
# Observability -- OpenTelemetry (optional)
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable distributed tracing (Jaeger, etc.)
# =============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTEL_SERVICE_NAME=ims-api

# =============================================================================
# Database Seed — required for ./seed.sh (interactive orchestration)
# The script always seeds plan limits + platform admin, then prompts for
# optional sample/minimal tenants. It does NOT read SEED_MODE / SEED_PROFILE /
# SEED_TENANTS from .env for behavior.
#
# Local legacy seed: see apps/api/prisma/seed.ts
# =============================================================================
SEED_PLATFORM_ADMIN_USERNAME=platform
SEED_PLATFORM_ADMIN_PASSWORD=STRONG-ADMIN-PASSWORD-HERE
# Optional default when minimal tenant list omits per-tenant :password
SEED_TENANT_PASSWORD=STRONG-TENANT-PASSWORD-HERE
