# Copy to .env on the EC2 instance and fill in real values.
# Used by docker-compose.dev.yml and docker-compose.prod.yml (env_file: .env).

# PostgreSQL (required)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=ims

# API (required)
# For dev, host should be dev_db; for prod, prod_db.
DATABASE_URL=postgresql://postgres:change-me-secure-password@dev_db:5432/ims
# For prod: postgresql://postgres:change-me-secure-password@prod_db:5432/ims
REDIS_URL=redis://dev_redis:6379
# For prod: redis://prod_redis:6379

# S3-compatible object storage (MinIO)
STORAGE_ENDPOINT=http://dev-minio:9000
# For prod: http://prod-minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=projectx-files
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=4h
JWT_REFRESH_TTL_DAYS=7
# API only – do not use for web (Next.js needs PORT=3000; compose overrides for dev_web/prod_web)
PORT=4000
HOST=0.0.0.0

# ============================================
# Web (Next.js) – proxy for same-origin API
# ============================================
# When using Next.js rewrites: client uses /api/v1 (same origin); Next proxies to API.
# NEXT_PUBLIC_API_URL: set at build time in CI (GitHub Actions) or in .env when building locally.
#   Use /api/v1 for proxy. Image must be built with this value for client to use same-origin.
# API_SERVER_URL: runtime, from .env on EC2. Next.js uses it for rewrite destination.
#   Dev stack: http://dev_api:4000  |  Prod stack: http://prod_api:4000
NEXT_PUBLIC_API_URL=/api/v1
API_SERVER_URL=http://dev_api:4000

# Optional superadmin (used by API if implemented)
# Seed (prisma:seed) - set SEED_MODE=production on prod for minimal seed
SEED_MODE=production
SEED_PLATFORM_ADMIN_USERNAME=platform
SEED_PLATFORM_ADMIN_PASSWORD=change-me

# Production only: comma-separated slug:Name (or slug:Name:password per tenant)
# Example: acme:Acme Corp,contoso:Contoso Ltd
SEED_TENANTS=
SEED_TENANT_PASSWORD=ChangeMe123!
