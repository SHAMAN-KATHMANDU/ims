# Copy to .env on the EC2 instance and fill in real values.
# Used by docker-compose.dev.yml and docker-compose.prod.yml (env_file: .env).

# PostgreSQL (required)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=ims

# API (required)
# For dev, host should be dev_db; for prod, prod_db.
DATABASE_URL=postgresql://postgres:change-me-secure-password@dev_db:5432/ims
# For prod: postgresql://postgres:change-me-secure-password@prod_db:5432/ims

JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=4000
HOST=0.0.0.0

# ============================================
# Staging: direct API (stage-ims + stage-api, no Next.js proxy)
# ============================================
# Client URL is set at BUILD time in apps/web/.env (NEXT_PUBLIC_API_URL).
# On EC2 you only need API CORS and optional CSP; nothing here changes the client bundle.
#
# API – required so browser allows requests from stage-ims to stage-api:
CORS_ORIGIN=https://stage-ims.shamankathmandu.com
# Optional CSP (quote the value if it contains commas):
# CSP_CONNECT_SRC="'self',https://stage-api.shamankathmandu.com"
#
# Not used for client when using direct API; leave or remove:
# API_SERVER_URL=http://dev_api:4000
# NEXT_PUBLIC_API_URL=...

# Optional superadmin (used by API if implemented)
# Web reads NEXT_PUBLIC_* at build time; set via GitHub Actions vars (DEV_UI / PROD_UI),
# not from this file on EC2.
# Seed (prisma:seed) - set SEED_MODE=production on prod for minimal seed
SEED_MODE=production
SEED_PLATFORM_ADMIN_USERNAME=platform
SEED_PLATFORM_ADMIN_PASSWORD=change-me

# Production only: comma-separated slug:Name (or slug:Name:password per tenant)
# Example: acme:Acme Corp,contoso:Contoso Ltd
SEED_TENANTS=
SEED_TENANT_PASSWORD=ChangeMe123!

# Redis (required for messaging queues and real-time)
REDIS_URL=redis://dev_redis:6379
# For prod: redis://prod_redis:6379

# Facebook Messenger Integration
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Credential Encryption (32-byte hex key for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=
