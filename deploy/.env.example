# Copy to .env on the EC2 instance and fill in real values.
# Used by docker-compose.dev.yml and docker-compose.prod.yml (env_file: .env).

# PostgreSQL (required)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=ims

# API (required)
# For dev, host should be dev_db; for prod, prod_db.
DATABASE_URL=postgresql://postgres:change-me-secure-password@dev_db:5432/ims
# For prod: postgresql://postgres:change-me-secure-password@prod_db:5432/ims

JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=4000
HOST=0.0.0.0

# ============================================
# Web (Next.js) – proxy for same-origin API
# ============================================
# If you see "localhost:4000" or "access control checks" on staging, the web image was built
# with the wrong API URL. NEXT_PUBLIC_* is baked in at BUILD time (not runtime).
#
# GitHub Actions (build-push-staging) writes vars.DEV_UI to apps/web/.env before building the
# web image. In GitHub: Settings → Secrets and variables → Actions → Variables, set DEV_UI to
# include this line (and any other web env you need), then re-run the workflow or push to main:
#   NEXT_PUBLIC_API_URL=/api/v1
#
# When using proxy: client requests same origin (e.g. https://your-stage.com/api/v1); Next rewrites to API.
# API_SERVER_URL: runtime, from .env. Next.js uses it for rewrite destination.
#   Dev stack: http://dev_api:4000  |  Prod stack: http://prod_api:4000
NEXT_PUBLIC_API_URL=/api/v1
API_SERVER_URL=http://dev_api:4000

# ============================================
# API – CORS (only if frontend calls API by full URL, not /api/v1 proxy)
# ============================================
# When using proxy above, CORS_ORIGIN is not required. If you use a separate API domain instead,
# set CORS_ORIGIN to the exact frontend origin (no trailing slash), e.g.:
# CORS_ORIGIN=https://stage.shamankathmandu.com

# Optional superadmin (used by API if implemented)
# Web reads NEXT_PUBLIC_* at build time; set via GitHub Actions vars (DEV_UI / PROD_UI),
# not from this file on EC2.
# Seed (prisma:seed) - set SEED_MODE=production on prod for minimal seed
SEED_MODE=production
SEED_PLATFORM_ADMIN_USERNAME=platform
SEED_PLATFORM_ADMIN_PASSWORD=change-me

# Production only: comma-separated slug:Name (or slug:Name:password per tenant)
# Example: acme:Acme Corp,contoso:Contoso Ltd
SEED_TENANTS=
SEED_TENANT_PASSWORD=ChangeMe123!
