# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored; do not commit secrets.

aws_region = "ap-south-1"

# Path to your public SSH key (e.g. generated with: ssh-keygen -t ed25519 -C "ims-aws" -f ~/.ssh/ims-aws -N "")
ssh_public_key_path = "~/.ssh/ims-aws.pub"

# Your public IP so only you can SSH (get it from https://ifconfig.me). Use "0.0.0.0" to allow any IP (not recommended).
my_ip = "0.0.0.0"

# Optional: t2.micro or t3.micro for free tier
# instance_type = "t2.micro"
