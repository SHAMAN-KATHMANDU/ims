generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-arm64-openssl-1.1.x"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  // Use a pre-created shadow DB to avoid P3014 / collation errors when your DB user
  // cannot create DBs or template1 has collation issues. Create a DB (e.g. ims_shadow)
  // and set SHADOW_DATABASE_URL in .env (see .env.example).
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ============================================
// MULTI-TENANT MODELS
// ============================================

model Tenant {
  id                 String             @id @default(uuid())
  name               String             // Display name: "Acme Corp"
  slug               String             @unique // URL slug: "acme" -> acme.ims.app
  plan               PlanTier           @default(STARTER)
  planExpiresAt      DateTime?          @map("plan_expires_at")
  isActive           Boolean            @default(true) @map("is_active")
  isTrial            Boolean            @default(true) @map("is_trial")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  settings           Json?
  /// Override plan limit for this tenant (null = use plan default). -1 = unlimited.
  customMaxUsers     Int?               @map("custom_max_users")
  customMaxProducts  Int?               @map("custom_max_products")
  customMaxLocations Int?               @map("custom_max_locations")
  customMaxMembers   Int?               @map("custom_max_members")
  customMaxCustomers Int?               @map("custom_max_customers")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  // Relations
  users                 User[]
  passwordResetRequests PasswordResetRequest[]
  categories            Category[]
  products       Product[]
  discountTypes  DiscountType[]
  vendors        Vendor[]
  locations      Location[]
  transfers      Transfer[]
  members        Member[]
  sales          Sale[]
  promoCodes     PromoCode[]
  auditLogs      AuditLog[]
  errorReports   ErrorReport[]
  subscriptions    Subscription[]
  payments         TenantPayment[]
  attributeTypes   AttributeType[]
  productVariations ProductVariation[]

  // CRM relations
  companies      Company[]
  contactTags    ContactTag[]
  contacts       Contact[]
  leads          Lead[]
  pipelines       Pipeline[]
  pipelineWorkflows PipelineWorkflow[]
  deals          Deal[]
  tasks          Task[]
  activities     Activity[]
  crmSources       CrmSource[]
  crmJourneyTypes  CrmJourneyType[]

  @@map("tenants")
}

enum PlanTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  LOCKED
  CANCELLED
}

model PlanLimit {
  id              String   @id @default(uuid())
  tier            PlanTier @unique
  maxUsers        Int      @map("max_users")
  maxProducts     Int      @map("max_products")
  maxLocations    Int      @map("max_locations")
  maxMembers      Int      @map("max_members")
  maxCustomers    Int      @map("max_customers")
  bulkUpload      Boolean  @default(false) @map("bulk_upload")
  analytics       Boolean  @default(false)
  promoManagement Boolean  @default(false) @map("promo_management")
  auditLogs       Boolean  @default(false) @map("audit_logs")
  apiAccess       Boolean  @default(false) @map("api_access")
  salesPipeline   Boolean  @default(false) @map("sales_pipeline")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("plan_limits")
}

model PricingPlan {
  id            String       @id @default(uuid())
  tier          PlanTier
  billingCycle  BillingCycle @map("billing_cycle")
  price         Decimal      @db.Decimal(12, 2)
  originalPrice Decimal?     @map("original_price") @db.Decimal(12, 2)
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@unique([tier, billingCycle])
  @@map("pricing_plans")
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

model Subscription {
  id                 String             @id @default(uuid())
  tenantId           String             @map("tenant_id")
  plan               PlanTier
  billingCycle       BillingCycle       @map("billing_cycle")
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  gracePeriodEnd     DateTime?          @map("grace_period_end")
  cancelledAt        DateTime?          @map("cancelled_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments TenantPayment[]

  @@map("subscriptions")
}

model TenantPayment {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  subscriptionId  String         @map("subscription_id")
  amount          Decimal        @db.Decimal(12, 2)
  currency        String         @default("NPR") @db.VarChar(10)
  gateway         PaymentGateway
  gatewayTxnId    String?        @map("gateway_txn_id") @db.VarChar(255)
  gatewayResponse Json?          @map("gateway_response")
  status          PaymentStatus  @default(PENDING)
  paidFor         PlanTier       @map("paid_for")
  billingCycle    BillingCycle   @map("billing_cycle")
  periodStart     DateTime       @map("period_start")
  periodEnd       DateTime       @map("period_end")
  verifiedAt      DateTime?      @map("verified_at")
  verifiedBy      String?        @map("verified_by")
  notes           String?        @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("tenant_payments")
}

enum PaymentGateway {
  ESEWA
  KHALTI
  FONEPAY
  CONNECTIPS
  BANK_TRANSFER
  MANUAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================
// USER MODEL
// ============================================

model User {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  username    String
  password    String
  role        Role      @default(user)
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  passwordResetRequestsRequested PasswordResetRequest[] @relation("ResetRequester")
  passwordResetRequestsHandled   PasswordResetRequest[] @relation("ResetHandler")
  productsCreated   Product[]     @relation("ProductCreator")
  transfersCreated  Transfer[]    @relation("TransferCreator")
  transfersApproved Transfer[]    @relation("TransferApprover")
  transferLogs      TransferLog[]
  salesCreated      Sale[]        @relation("SaleCreator")
  salesDeleted      Sale[]        @relation("SaleDeletedBy")
  salesEdited       Sale[]        @relation("SaleEditedBy")
  saleItemsApprovedForDiscount SaleItem[] @relation("DiscountApprover")
  auditLogs         AuditLog[]
  errorReports      ErrorReport[]

  // CRM relations
  assignedLeads         Lead[]            @relation("LeadAssignedTo")
  assignedDeals         Deal[]            @relation("DealAssignedTo")
  assignedTasks         Task[]
  contactNotes          ContactNote[]
  contactCommunications ContactCommunication[]
  contactAttachments    ContactAttachment[]
  notifications         Notification[]
  ownedContacts         Contact[]         @relation("ContactOwner")
  createdContacts       Contact[]         @relation("ContactCreator")
  activitiesCreated     Activity[]
  dealsCreated          Deal[]            @relation("DealCreator")
  leadsCreated          Lead[]            @relation("LeadCreator")

  @@unique([tenantId, username])
  @@map("users")
}

enum Role {
  platformAdmin
  superAdmin
  admin
  user
}

enum PasswordResetStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

model PasswordResetRequest {
  id            String              @id @default(uuid()) @map("reset_request_id")
  tenantId      String              @map("tenant_id")
  requestedById String              @map("requested_by_id")
  status        PasswordResetStatus @default(PENDING)
  escalated     Boolean             @default(false)
  handledById   String?             @map("handled_by_id")
  handledAt     DateTime?           @map("handled_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy User   @relation("ResetRequester", fields: [requestedById], references: [id])
  handledBy   User?  @relation("ResetHandler", fields: [handledById], references: [id])

  @@map("password_reset_requests")
}

// ============================================
// PRODUCT MODELS
// ============================================

model Category {
  id           String    @id @default(uuid()) @map("category_id")
  tenantId     String    @map("tenant_id")
  name         String    @map("category_name") @db.VarChar(255)
  description  String?   @db.Text
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by")
  deleteReason String?   @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products      Product[]
  subCategories SubCategory[]

  @@unique([tenantId, name])
  @@map("categories")
}

model SubCategory {
  id           String    @id @default(uuid()) @map("sub_category_id")
  name         String    @db.VarChar(255)
  categoryId   String    @map("category_id")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by")
  deleteReason String?   @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, name])
  @@map("sub_categories")
}

model Product {
  id            String   @id @default(uuid()) @map("product_id")
  tenantId      String   @map("tenant_id")
  /// Unique per-tenant product barcode / IMS code (scanned at POS to fetch product and choose variation).
  imsCode       String   @map("ims_code") @db.VarChar(100)
  name          String   @map("product_name") @db.VarChar(255)
  categoryId    String   @map("category_id")
  /// Optional sub-category label for further grouping within a category (denormalized name)
  subCategory   String?  @map("sub_category") @db.VarChar(255)
  /// Optional relation to sub-category entity
  subCategoryId String?  @map("sub_category_id")
  description   String?  @db.Text
  length        Decimal? @db.Decimal(10, 2)
  breadth       Decimal? @db.Decimal(10, 2)
  height        Decimal? @db.Decimal(10, 2)
  weight        Decimal? @db.Decimal(10, 2)
  /// Base cost price (for margin analytics)
  costPrice     Decimal  @map("cost_price") @db.Decimal(10, 2)
  /// MRP / list price (before discounts)
  mrp           Decimal  @db.Decimal(10, 2)
  /// Default selling price used as the base for discount calculations
  finalSp       Decimal  @default(0) @map("final_sp") @db.Decimal(10, 2)
  /// Optional vendor this product is sourced from
  vendorId      String?  @map("vendor_id")
  createdById   String    @map("created_by_id")
  dateCreated   DateTime  @default(now()) @map("date_created")
  dateModified  DateTime  @updatedAt @map("date_modified")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     String?   @map("deleted_by")
  deleteReason  String?   @map("delete_reason") @db.VarChar(500)

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy    User             @relation("ProductCreator", fields: [createdById], references: [id], onDelete: Restrict)
  vendor       Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  subCategoryRel SubCategory?   @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  variations           ProductVariation[]
  discounts            ProductDiscount[]
  promoCodes           PromoCodeProduct[]
  productAttributeTypes ProductAttributeType[]
  dealLineItems        DealLineItem[]

  @@unique([tenantId, imsCode])
  @@map("products")
}

// ============================================
// EAV-STYLE VARIATION ATTRIBUTES (tenant-customizable)
// ============================================

model AttributeType {
  id           String   @id @default(uuid()) @map("attribute_type_id")
  tenantId     String   @map("tenant_id")
  name         String   @map("name") @db.VarChar(100)
  code         String   @map("code") @db.VarChar(50)
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  values    AttributeValue[]
  productAttributeTypes ProductAttributeType[]
  variationAttributes   ProductVariationAttribute[]

  @@unique([tenantId, code])
  @@map("attribute_types")
}

model AttributeValue {
  id              String   @id @default(uuid()) @map("attribute_value_id")
  attributeTypeId String   @map("attribute_type_id")
  value           String   @map("value") @db.VarChar(255)
  code            String?  @map("code") @db.VarChar(50)
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  attributeType         AttributeType              @relation(fields: [attributeTypeId], references: [id], onDelete: Cascade)
  productVariationAttributes ProductVariationAttribute[]

  @@unique([attributeTypeId, value])
  @@map("attribute_values")
}

/// Which attribute types apply to a product (e.g. this product uses Color + Size)
model ProductAttributeType {
  productId       String @map("product_id")
  attributeTypeId String @map("attribute_type_id")
  displayOrder    Int    @default(0) @map("display_order")

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeType AttributeType @relation(fields: [attributeTypeId], references: [id], onDelete: Cascade)

  @@id([productId, attributeTypeId])
  @@map("product_attribute_types")
}

model ProductVariation {
  id                String   @id @default(uuid()) @map("variation_id")
  tenantId          String   @map("tenant_id")
  productId         String   @map("product_id")
  /// Optional overrides; when null, product base price is used
  costPriceOverride Decimal? @map("cost_price_override") @db.Decimal(10, 2)
  mrpOverride       Decimal? @map("mrp_override") @db.Decimal(10, 2)
  finalSpOverride   Decimal? @map("final_sp_override") @db.Decimal(10, 2)
  isActive          Boolean  @default(true) @map("is_active")
  stockQuantity     Int      @default(0) @map("stock_quantity")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product           Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes        ProductVariationAttribute[]
  subVariations     ProductSubVariation[]
  photos            VariationPhoto[]
  locationInventory LocationInventory[]
  transferItems     TransferItem[]
  saleItems         SaleItem[]
  dealLineItems     DealLineItem[]

  @@map("product_variations")
}

/// EAV: links a variation to one value per attribute type (e.g. Color=Red, Size=M)
model ProductVariationAttribute {
  variationId       String @map("variation_id")
  attributeTypeId   String @map("attribute_type_id")
  attributeValueId  String @map("attribute_value_id")

  variation      ProductVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)
  attributeType  AttributeType   @relation(fields: [attributeTypeId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue  @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variationId, attributeTypeId])
  @@map("product_variation_attributes")
}

model ProductSubVariation {
  id          String   @id @default(uuid()) @map("sub_variation_id")
  variationId String   @map("variation_id")
  name        String   @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  variation         ProductVariation    @relation(fields: [variationId], references: [id], onDelete: Cascade)
  locationInventory LocationInventory[]
  transferItems     TransferItem[]
  saleItems         SaleItem[]

  @@unique([variationId, name])
  @@map("product_sub_variations")
}

model VariationPhoto {
  id          String   @id @default(uuid()) @map("photo_id")
  variationId String   @map("variation_id")
  photoUrl    String   @map("photo_url") @db.VarChar(500)
  isPrimary   Boolean  @default(false) @map("is_primary")
  uploadDate  DateTime @default(now()) @map("upload_date")

  variation ProductVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@map("variation_photos")
}

model DiscountType {
  id                String    @id @default(uuid()) @map("discount_type_id")
  tenantId          String    @map("tenant_id")
  name              String    @map("type_name") @db.VarChar(100)
  description       String?   @db.Text
  /// Default percentage off (0–100) when this discount type is used; optional
  defaultPercentage Decimal?  @map("default_percentage") @db.Decimal(5, 2)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productDiscounts ProductDiscount[]

  @@unique([tenantId, name])
  @@map("discount_types")
}

/// How a discount or promo value should be interpreted
enum DiscountValueType {
  PERCENTAGE
  FLAT
}

model ProductDiscount {
  id                 String            @id @default(uuid()) @map("discount_id")
  productId          String            @map("product_id")
  discountTypeId     String            @map("discount_type_id")
  /// Legacy percentage field (kept for backwards compatibility)
  discountPercentage Decimal           @map("discount_percentage") @db.Decimal(5, 2)
  /// New flexible discount configuration
  valueType          DiscountValueType @default(PERCENTAGE) @map("value_type")
  /// When valueType = PERCENTAGE this is a percentage (0-100); when FLAT this is a currency amount
  value              Decimal           @default(0) @map("value") @db.Decimal(12, 2)
  startDate          DateTime?         @map("start_date")
  endDate            DateTime?         @map("end_date")
  isActive           Boolean           @default(true) @map("is_active")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountType DiscountType @relation(fields: [discountTypeId], references: [id], onDelete: Restrict)

  @@unique([productId, discountTypeId])
  @@map("product_discounts")
}

// ============================================
// VENDOR MODEL
// ============================================

model Vendor {
  id           String    @id @default(uuid()) @map("vendor_id")
  tenantId     String    @map("tenant_id")
  name         String    @db.VarChar(255)
  contact      String?   @db.VarChar(255)
  phone        String?   @db.VarChar(50)
  address      String?   @db.Text
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by")
  deleteReason String?   @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@map("vendors")
}

// ============================================
// LOCATION & INVENTORY MODELS
// ============================================

model Location {
  id                 String       @id @default(uuid()) @map("location_id")
  tenantId           String       @map("tenant_id")
  name               String       @map("location_name") @db.VarChar(255)
  type               LocationType @default(SHOWROOM)
  address            String?      @db.Text
  isActive           Boolean      @default(true) @map("is_active")
  /// When true, new product stock is added here by default; only one warehouse should be default
  isDefaultWarehouse Boolean      @default(false) @map("is_default_warehouse")
  deletedAt          DateTime?    @map("deleted_at")
  deletedBy          String?      @map("deleted_by")
  deleteReason       String?      @map("delete_reason") @db.VarChar(500)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventory     LocationInventory[]
  transfersFrom Transfer[]          @relation("TransferFrom")
  transfersTo   Transfer[]          @relation("TransferTo")
  sales         Sale[]

  @@unique([tenantId, name])
  @@map("locations")
}

enum LocationType {
  WAREHOUSE
  SHOWROOM
}

model LocationInventory {
  id             String   @id @default(uuid()) @map("inventory_id")
  locationId     String   @map("location_id")
  variationId    String   @map("variation_id")
  subVariationId String?  @map("sub_variation_id")
  quantity       Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  location     Location              @relation(fields: [locationId], references: [id], onDelete: Restrict)
  variation    ProductVariation      @relation(fields: [variationId], references: [id], onDelete: Cascade)
  subVariation ProductSubVariation?  @relation(fields: [subVariationId], references: [id], onDelete: Cascade)

  @@unique([locationId, variationId, subVariationId])
  @@map("location_inventory")
}

// ============================================
// TRANSFER MODELS
// ============================================

model Transfer {
  id             String         @id @default(uuid()) @map("transfer_id")
  tenantId       String         @map("tenant_id")
  transferCode   String         @map("transfer_code") @db.VarChar(50)
  fromLocationId String         @map("from_location_id")
  toLocationId   String         @map("to_location_id")
  status         TransferStatus @default(PENDING)
  notes          String?        @db.Text
  createdById    String         @map("created_by_id")
  approvedById   String?        @map("approved_by_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  approvedAt     DateTime?      @map("approved_at")
  completedAt    DateTime?      @map("completed_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromLocation Location       @relation("TransferFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   Location       @relation("TransferTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  createdBy    User           @relation("TransferCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy   User?          @relation("TransferApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  items        TransferItem[]
  logs         TransferLog[]

  @@unique([tenantId, transferCode])
  @@map("transfers")
}

enum TransferStatus {
  PENDING
  APPROVED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model TransferItem {
  id             String  @id @default(uuid()) @map("transfer_item_id")
  transferId     String  @map("transfer_id")
  variationId    String  @map("variation_id")
  subVariationId String? @map("sub_variation_id")
  quantity       Int

  transfer     Transfer              @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variation    ProductVariation      @relation(fields: [variationId], references: [id], onDelete: Restrict)
  subVariation ProductSubVariation?  @relation(fields: [subVariationId], references: [id], onDelete: Restrict)

  @@unique([transferId, variationId, subVariationId])
  @@map("transfer_items")
}

model TransferLog {
  id         String   @id @default(uuid()) @map("log_id")
  transferId String   @map("transfer_id")
  action     String   @db.VarChar(50)
  details    Json?
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("transfer_logs")
}

// ============================================
// MEMBER & SALES MODELS
// ============================================

model Member {
  id            String       @id @default(uuid()) @map("member_id")
  tenantId      String       @map("tenant_id")
  phone         String       @db.VarChar(20)
  name          String?      @db.VarChar(255)
  email         String?      @db.VarChar(255)
  notes         String?      @db.Text
  isActive      Boolean      @default(true) @map("is_active")
  gender        String?      @db.VarChar(20)
  age           Int?
  address       String?      @db.Text
  birthday      DateTime?
  /// Aggregated lifetime sales amount for this customer
  totalSales    Decimal?     @default(0) @map("total_sales") @db.Decimal(12, 2)
  /// Membership status (e.g. VIP, Active, etc.)
  memberStatus  MemberStatus @default(ACTIVE) @map("member_status")
  /// When the customer became a member
  memberSince   DateTime?    @map("member_since")
  /// First purchase date
  firstPurchase DateTime?    @map("first_purchase")
  deletedAt     DateTime?    @map("deleted_at")
  deletedBy     String?      @map("deleted_by")
  deleteReason  String?      @map("delete_reason") @db.VarChar(500)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales      Sale[]
  contact    Contact?
  deals      Deal[]     @relation("DealMember")
  tasks      Task[]     @relation("TaskMember")
  activities Activity[] @relation("ActivityMember")

  @@unique([tenantId, phone])
  @@map("members")
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  VIP
}

model Sale {
  id               String   @id @default(uuid()) @map("sale_id")
  tenantId         String   @map("tenant_id")
  saleCode         String   @map("sale_code") @db.VarChar(50)
  type             SaleType @default(GENERAL)
  isCreditSale     Boolean  @default(false) @map("is_credit_sale")
  locationId       String   @map("location_id")
  memberId         String?  @map("member_id")
  contactId        String?  @map("contact_id")
  subtotal         Decimal  @db.Decimal(12, 2)
  discount         Decimal  @default(0) @db.Decimal(12, 2)
  promoDiscount    Decimal  @default(0) @map("promo_discount") @db.Decimal(12, 2)
  total            Decimal  @db.Decimal(12, 2)
  notes            String?  @db.Text
  promoCodesUsed   Json?    @map("promo_codes_used")
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by")
  deleteReason     String?   @map("delete_reason") @db.VarChar(500)
  parentSaleId     String?   @map("parent_sale_id")
  revisionNo       Int       @default(1) @map("revision_no")
  isLatest         Boolean   @default(true) @map("is_latest")
  editReason       String?   @map("edit_reason") @db.VarChar(500)
  editedById       String?   @map("edited_by_id")
  editedAt         DateTime? @map("edited_at")

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location   Location     @relation(fields: [locationId], references: [id], onDelete: Restrict)
  member     Member?      @relation(fields: [memberId], references: [id], onDelete: Restrict)
  contact    Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdBy  User         @relation("SaleCreator", fields: [createdById], references: [id], onDelete: Restrict)
  deletedBy  User?        @relation("SaleDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  editedBy   User?        @relation("SaleEditedBy", fields: [editedById], references: [id], onDelete: SetNull)
  parentSale Sale?        @relation("SaleRevisions", fields: [parentSaleId], references: [id], onDelete: SetNull)
  revisions  Sale[]       @relation("SaleRevisions")
  items      SaleItem[]
  payments   SalePayment[]

  @@unique([tenantId, saleCode])
  @@map("sales")
}

enum SaleType {
  GENERAL
  MEMBER
}

model SaleItem {
  id                    String   @id @default(uuid()) @map("sale_item_id")
  saleId                String   @map("sale_id")
  variationId           String   @map("variation_id")
  subVariationId        String?  @map("sub_variation_id")
  quantity              Int
  /// Snapshot of the MRP / unit price at the time of sale
  unitPrice             Decimal  @db.Decimal(10, 2)
  /// Total MRP (unitPrice * quantity) at the time of sale
  totalMrp              Decimal  @default(0) @map("total_mrp") @db.Decimal(12, 2)
  /// Percentage discount applied on this line (derived from product discounts & promo codes)
  discountPercent       Decimal  @default(0) @map("discount_percent") @db.Decimal(5, 2)
  /// Absolute discount value applied on this line
  discountAmount        Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  /// Final payable for this line after all discounts
  lineTotal             Decimal  @map("line_total") @db.Decimal(12, 2)
  /// Enterprise: manual discount percent (overrides product discount when set)
  manualDiscountPercent Decimal? @map("manual_discount_percent") @db.Decimal(5, 2)
  /// Enterprise: manual discount amount (overrides product discount when set)
  manualDiscountAmount  Decimal? @map("manual_discount_amount") @db.Decimal(12, 2)
  /// User who approved the manual discount (audit trail)
  discountApprovedById  String?  @map("discount_approved_by_id")
  /// Reason for manual discount (required when manual discount is applied)
  discountReason        String?  @map("discount_reason") @db.VarChar(500)

  sale               Sale                  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variation          ProductVariation      @relation(fields: [variationId], references: [id], onDelete: Restrict)
  subVariation       ProductSubVariation?  @relation(fields: [subVariationId], references: [id], onDelete: Restrict)
  discountApprovedBy User?                 @relation("DiscountApprover", fields: [discountApprovedById], references: [id], onDelete: SetNull)

  @@map("sale_items")
}

// ============================================
// PAYMENT & PROMO MODELS
// ============================================

enum PaymentMethod {
  CASH
  CARD
  CHEQUE
  FONEPAY
  QR
}

model SalePayment {
  id        String        @id @default(uuid()) @map("payment_id")
  saleId    String        @map("sale_id")
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  createdAt DateTime      @default(now()) @map("created_at")

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_payments")
}

enum PromoEligibility {
  ALL
  MEMBER
  NON_MEMBER
  WHOLESALE
}

model PromoCode {
  id                String            @id @default(uuid()) @map("promo_id")
  tenantId          String            @map("tenant_id")
  code              String            @db.VarChar(50)
  description       String?           @db.Text
  valueType         DiscountValueType @map("value_type")
  value             Decimal           @db.Decimal(12, 2)
  overrideDiscounts Boolean           @default(false) @map("override_discounts")
  allowStacking     Boolean           @default(false) @map("allow_stacking")
  eligibility       PromoEligibility  @default(ALL)
  validFrom         DateTime?         @map("valid_from")
  validTo           DateTime?         @map("valid_to")
  usageLimit        Int?              @map("usage_limit")
  usageCount        Int               @default(0) @map("usage_count")
  isActive          Boolean           @default(true) @map("is_active")
  deletedAt         DateTime?         @map("deleted_at")
  deletedBy         String?           @map("deleted_by")
  deleteReason      String?           @map("delete_reason") @db.VarChar(500)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products PromoCodeProduct[]

  @@unique([tenantId, code])
  @@map("promo_codes")
}

model PromoCodeProduct {
  id          String @id @default(uuid()) @map("promo_product_id")
  promoCodeId String @map("promo_id")
  productId   String @map("product_id")

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, productId])
  @@map("promo_code_products")
}

// ============================================
// AUDIT LOG (User actions)
// ============================================

model AuditLog {
  id         String   @id @default(uuid()) @map("audit_log_id")
  tenantId   String?  @map("tenant_id")
  userId     String   @map("user_id")
  action     String   @map("action") @db.VarChar(100)
  resource   String?  @map("resource") @db.VarChar(100)
  resourceId String?  @map("resource_id") @db.VarChar(100)
  details    Json?
  ip         String?  @map("ip") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("audit_logs")
}

// ============================================
// ERROR REPORTS (from top bar)
// ============================================

enum ErrorReportStatus {
  OPEN
  REVIEWED
  RESOLVED
}

model ErrorReport {
  id          String            @id @default(uuid()) @map("error_report_id")
  tenantId    String?           @map("tenant_id")
  userId      String            @map("user_id")
  title       String            @map("title") @db.VarChar(255)
  description String?           @map("description") @db.Text
  pageUrl     String?           @map("page_url") @db.VarChar(500)
  status      ErrorReportStatus @default(OPEN) @map("status")
  createdAt   DateTime          @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("error_reports")
}

// ============================================
// CRM MODELS
// ============================================

model Company {
  id           String    @id @default(uuid()) @map("company_id")
  tenantId     String    @map("tenant_id")
  name         String    @map("company_name") @db.VarChar(255)
  website      String?   @db.VarChar(500)
  address      String?   @db.Text
  phone        String?   @db.VarChar(50)
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by")
  deleteReason String?   @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts Contact[]
  deals    Deal[]

  @@index([tenantId])
  @@map("companies")
}

model ContactTag {
  id        String   @id @default(uuid()) @map("tag_id")
  tenantId  String   @map("tenant_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts ContactTagLink[]

  @@index([tenantId])
  @@unique([tenantId, name])
  @@map("contact_tags")
}

model ContactTagLink {
  contactId String @map("contact_id")
  tagId     String @map("tag_id")

  contact Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     ContactTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tag_links")
}

model Contact {
  id           String   @id @default(uuid()) @map("contact_id")
  tenantId     String   @map("tenant_id")
  firstName    String   @map("first_name") @db.VarChar(255)
  lastName     String?  @map("last_name") @db.VarChar(255)
  email        String?  @db.VarChar(255)
  phone        String?  @db.VarChar(50)
  companyId    String?  @map("company_id")
  memberId     String?  @unique @map("member_id")
  ownedById    String    @map("owned_by_id")
  createdById  String    @map("created_by_id")
  source       String?  @db.VarChar(100)
  journeyType  String?  @map("journey_type") @db.VarChar(100)
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?  @map("deleted_by")
  deleteReason String?  @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company        Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  member         Member?                @relation(fields: [memberId], references: [id], onDelete: SetNull)
  owner          User                   @relation("ContactOwner", fields: [ownedById], references: [id], onDelete: Restrict)
  creator        User                   @relation("ContactCreator", fields: [createdById], references: [id], onDelete: Restrict)
  tagLinks       ContactTagLink[]
  notes          ContactNote[]
  attachments    ContactAttachment[]
  communications ContactCommunication[]
  deals          Deal[]
  tasks          Task[]
  activities     Activity[]
  sales          Sale[]

  @@index([tenantId])
  @@map("contacts")
}

model ContactNote {
  id        String   @id @default(uuid()) @map("note_id")
  contactId String   @map("contact_id")
  content   String   @db.Text
  createdById String @map("created_by_id")
  createdAt DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@map("contact_notes")
}

model ContactAttachment {
  id        String   @id @default(uuid()) @map("attachment_id")
  contactId String   @map("contact_id")
  fileName  String   @map("file_name") @db.VarChar(255)
  filePath  String   @map("file_path") @db.VarChar(500)
  fileSize  Int?     @map("file_size")
  mimeType  String?  @map("mime_type") @db.VarChar(100)
  uploadedById String @map("uploaded_by_id")
  createdAt DateTime @default(now()) @map("created_at")

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  uploader  User    @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@map("contact_attachments")
}

enum CommunicationType {
  CALL
  EMAIL
  MEETING
}

model ContactCommunication {
  id        String            @id @default(uuid()) @map("communication_id")
  contactId String            @map("contact_id")
  type      CommunicationType
  subject   String?           @db.VarChar(500)
  notes     String?           @db.Text
  createdById String          @map("created_by_id")
  createdAt DateTime         @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@map("contact_communications")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  CONVERTED
}

model Lead {
  id           String     @id @default(uuid()) @map("lead_id")
  tenantId     String    @map("tenant_id")
  name         String     @map("lead_name") @db.VarChar(255)
  email        String?    @db.VarChar(255)
  phone        String?    @db.VarChar(50)
  companyName  String?    @map("company_name") @db.VarChar(255)
  status       LeadStatus @default(NEW)
  source       String?    @db.VarChar(100)
  notes        String?    @db.Text
  assignedToId String     @map("assigned_to_id")
  createdById  String     @map("created_by_id")
  convertedAt  DateTime?  @map("converted_at")
  deletedAt    DateTime?  @map("deleted_at")
  deletedBy    String?    @map("deleted_by")
  deleteReason String?    @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo  User   @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: Restrict)
  creator     User   @relation("LeadCreator", fields: [createdById], references: [id], onDelete: Restrict)
  convertedDeal Deal?

  @@index([tenantId])
  @@map("leads")
}

model Pipeline {
  id           String    @id @default(uuid()) @map("pipeline_id")
  tenantId     String    @map("tenant_id")
  name         String    @db.VarChar(255)
  stages       Json      // Array of { id, name, order, probability }
  isDefault    Boolean   @default(false) @map("is_default")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by")
  deleteReason String?   @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deals           Deal[]
  pipelineWorkflows PipelineWorkflow[]

  @@index([tenantId])
  @@map("pipelines")
}

enum WorkflowTrigger {
  STAGE_ENTER
  STAGE_EXIT
  DEAL_CREATED
  DEAL_WON
  DEAL_LOST
}

enum WorkflowAction {
  CREATE_TASK
  SEND_NOTIFICATION
  MOVE_STAGE
  UPDATE_FIELD
  CREATE_ACTIVITY
}

model PipelineWorkflow {
  id         String   @id @default(uuid()) @map("workflow_id")
  tenantId   String   @map("tenant_id")
  pipelineId String   @map("pipeline_id")
  name       String   @db.VarChar(255)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  rules    WorkflowRule[]

  @@unique([tenantId, pipelineId, name])
  @@index([tenantId])
  @@index([pipelineId])
  @@map("pipeline_workflows")
}

model WorkflowRule {
  id             String          @id @default(uuid()) @map("rule_id")
  workflowId     String          @map("workflow_id")
  trigger        WorkflowTrigger
  triggerStageId String?         @map("trigger_stage_id") @db.VarChar(100) // stage id/name for STAGE_ENTER/EXIT
  action         WorkflowAction
  actionConfig   Json            @map("action_config") // e.g. { taskTitle, assigneeId, targetStageId }
  ruleOrder      Int             @default(0) @map("rule_order")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  workflow PipelineWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_rules")
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id                 String    @id @default(uuid()) @map("deal_id")
  tenantId           String   @map("tenant_id")
  name               String    @map("deal_name") @db.VarChar(255)
  value              Decimal   @db.Decimal(12, 2)
  stage              String    @db.VarChar(100)
  probability        Int       @default(0) // 0-100
  status             DealStatus @default(OPEN)
  expectedCloseDate  DateTime? @map("expected_close_date")
  closedAt           DateTime? @map("closed_at")
  lostReason         String?   @map("lost_reason") @db.VarChar(255)
  contactId          String?   @map("contact_id")
  memberId           String?   @map("member_id")
  companyId          String?   @map("company_id")
  pipelineId         String    @map("pipeline_id")
  assignedToId       String    @map("assigned_to_id")
  createdById        String    @map("created_by_id")
  leadId             String?   @unique @map("lead_id")
  deletedAt          DateTime? @map("deleted_at")
  deletedBy          String?   @map("deleted_by")
  deleteReason       String?   @map("delete_reason") @db.VarChar(500)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact    Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  member     Member?   @relation("DealMember", fields: [memberId], references: [id], onDelete: SetNull)
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  pipeline   Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  assignedTo User      @relation("DealAssignedTo", fields: [assignedToId], references: [id], onDelete: Restrict)
  creator    User      @relation("DealCreator", fields: [createdById], references: [id], onDelete: Restrict)
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  tasks      Task[]
  activities Activity[]
  lineItems  DealLineItem[]

  @@index([tenantId])
  @@map("deals")
}

model DealLineItem {
  id          String   @id @default(uuid()) @map("deal_line_item_id")
  dealId      String   @map("deal_id")
  productId   String   @map("product_id")
  variationId String?  @map("variation_id")
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  variation   ProductVariation? @relation(fields: [variationId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@map("deal_line_items")
}

model Task {
  id           String    @id @default(uuid()) @map("task_id")
  tenantId     String    @map("tenant_id")
  title        String    @db.VarChar(500)
  dueDate      DateTime? @map("due_date")
  completed    Boolean   @default(false)
  contactId    String?   @map("contact_id")
  memberId     String?   @map("member_id")
  dealId       String?   @map("deal_id")
  assignedToId String    @map("assigned_to_id")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by")
  deleteReason String?   @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  member     Member?  @relation("TaskMember", fields: [memberId], references: [id], onDelete: SetNull)
  deal       Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  assignedTo User     @relation(fields: [assignedToId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("tasks")
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
}

model Activity {
  id         String       @id @default(uuid()) @map("activity_id")
  tenantId   String      @map("tenant_id")
  type       ActivityType
  subject    String?      @db.VarChar(500)
  notes      String?      @db.Text
  activityAt DateTime    @map("activity_at")
  contactId  String?     @map("contact_id")
  memberId   String?     @map("member_id")
  dealId     String?     @map("deal_id")
  createdById String     @map("created_by_id")
  deletedAt  DateTime?   @map("deleted_at")
  deletedBy  String?     @map("deleted_by")
  deleteReason String?   @map("delete_reason") @db.VarChar(500)
  createdAt  DateTime    @default(now()) @map("created_at")

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  member    Member?  @relation("ActivityMember", fields: [memberId], references: [id], onDelete: SetNull)
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  creator   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("activities")
}

model CrmSource {
  id        String   @id @default(uuid()) @map("crm_source_id")
  tenantId  String   @map("tenant_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("crm_sources")
}

model CrmJourneyType {
  id        String   @id @default(uuid()) @map("crm_journey_type_id")
  tenantId  String   @map("tenant_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("crm_journey_types")
}

enum NotificationType {
  TASK_DUE
  DEAL_STAGE_CHANGE
  LEAD_ASSIGNMENT
}

model Notification {
  id           String           @id @default(uuid()) @map("notification_id")
  userId       String           @map("user_id")
  type         NotificationType
  title        String           @map("title") @db.VarChar(255)
  message      String?          @db.Text
  resourceType String?          @map("resource_type") @db.VarChar(50)
  resourceId   String?          @map("resource_id") @db.VarChar(100)
  readAt       DateTime?        @map("read_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
