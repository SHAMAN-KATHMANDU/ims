model PipelineWorkflow {
  id              String         @id @default(uuid()) @map("workflow_id")
  tenantId        String         @map("tenant_id")
  pipelineId      String         @map("pipeline_id")
  name            String         @db.VarChar(255)
  description     String?        @db.VarChar(500)
  isActive        Boolean        @default(true) @map("is_active")
  templateKey     String?        @map("template_key") @db.VarChar(120)
  templateVersion Int?           @map("template_version")
  origin          WorkflowOrigin @default(CUSTOM)
  version         Int            @default(1)
  publishedAt     DateTime?      @map("published_at")
  lastRunAt       DateTime?      @map("last_run_at")
  lastErrorAt     DateTime?      @map("last_error_at")
  runCount        Int            @default(0) @map("run_count")
  failureCount    Int            @default(0) @map("failure_count")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline     Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  rules        WorkflowRule[]
  workflowRuns WorkflowRun[]

  @@unique([tenantId, pipelineId, name])
  @@unique([tenantId, templateKey])
  @@index([tenantId])
  @@index([pipelineId])
  @@index([tenantId, templateKey])
  @@map("pipeline_workflows")
}

model WorkflowRule {
  id             String          @id @default(uuid()) @map("rule_id")
  workflowId     String          @map("workflow_id")
  trigger        WorkflowTrigger
  triggerStageId String?         @map("trigger_stage_id") @db.VarChar(100) // stage id/name for STAGE_ENTER/EXIT
  action         WorkflowAction
  actionConfig   Json            @map("action_config") // e.g. { taskTitle, assigneeId, targetStageId }
  ruleOrder      Int             @default(0) @map("rule_order")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  workflow PipelineWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_rules")
}

model WorkflowRun {
  id           String            @id @default(uuid()) @map("workflow_run_id")
  tenantId     String            @map("tenant_id")
  workflowId   String            @map("workflow_id")
  ruleId       String?           @map("rule_id")
  trigger      WorkflowTrigger
  action       WorkflowAction?
  status       WorkflowRunStatus
  entityType   String            @default("DEAL") @map("entity_type") @db.VarChar(50)
  entityId     String            @map("entity_id")
  dedupeKey    String?           @map("dedupe_key") @db.VarChar(255)
  attempt      Int               @default(1)
  errorMessage String?           @map("error_message") @db.VarChar(2000)
  metadata     Json?
  startedAt    DateTime          @default(now()) @map("started_at")
  completedAt  DateTime?         @map("completed_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow PipelineWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, dedupeKey])
  @@index([tenantId, workflowId, startedAt])
  @@index([workflowId, status])
  @@map("workflow_runs")
}

model AutomationDefinition {
  id                      String                  @id @default(uuid()) @map("automation_definition_id")
  tenantId                String                  @map("tenant_id")
  name                    String                  @db.VarChar(255)
  description             String?                 @db.VarChar(1000)
  scopeType               AutomationScopeType     @map("scope_type")
  scopeId                 String?                 @map("scope_id")
  status                  AutomationStatus        @default(ACTIVE)
  source                  AutomationSource        @default(MANUAL)
  executionMode           AutomationExecutionMode @default(LIVE) @map("execution_mode")
  suppressLegacyWorkflows Boolean                 @default(false) @map("suppress_legacy_workflows")
  version                 Int                     @default(1)
  /// Phase 3 DAG body (JSON). When set, `steps` must be empty (BR-19).
  flowGraph               Json?                   @map("flow_graph")
  createdById             String                  @map("created_by_id")
  updatedById             String?                 @map("updated_by_id")
  publishedAt             DateTime?               @map("published_at")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation("AutomationDefinitionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User?                  @relation("AutomationDefinitionUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  triggers    AutomationTrigger[]
  steps       AutomationStep[]
  runs        AutomationRun[]
  delayedRuns AutomationDelayedRun[]
  workItems   WorkItem[]

  @@unique([tenantId, scopeType, scopeId, name])
  @@index([tenantId, status])
  @@index([tenantId, scopeType, scopeId])
  @@map("automation_definitions")
}

model AutomationTrigger {
  id              String   @id @default(uuid()) @map("automation_trigger_id")
  automationId    String   @map("automation_definition_id")
  eventName       String   @map("event_name") @db.VarChar(120)
  conditionGroups Json?    @map("condition_groups")
  delayMinutes    Int      @default(0) @map("delay_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  automation  AutomationDefinition   @relation(fields: [automationId], references: [id], onDelete: Cascade)
  delayedRuns AutomationDelayedRun[]

  @@index([automationId])
  @@index([eventName])
  @@map("automation_triggers")
}

model AutomationStep {
  id              String   @id @default(uuid()) @map("automation_step_id")
  automationId    String   @map("automation_definition_id")
  stepOrder       Int      @default(0) @map("step_order")
  actionType      String   @map("action_type") @db.VarChar(120)
  actionConfig    Json     @map("action_config")
  continueOnError Boolean  @default(false) @map("continue_on_error")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  automation AutomationDefinition @relation(fields: [automationId], references: [id], onDelete: Cascade)
  runSteps   AutomationRunStep[]

  @@index([automationId, stepOrder])
  @@map("automation_steps")
}

model AutomationEvent {
  id                  String                @id @default(uuid()) @map("automation_event_id")
  tenantId            String                @map("tenant_id")
  eventName           String                @map("event_name") @db.VarChar(120)
  scopeType           AutomationScopeType?  @map("scope_type")
  scopeId             String?               @map("scope_id")
  entityType          String                @map("entity_type") @db.VarChar(100)
  entityId            String                @map("entity_id")
  actorUserId         String?               @map("actor_user_id")
  dedupeKey           String?               @map("dedupe_key") @db.VarChar(255)
  status              AutomationEventStatus @default(PENDING)
  attempts            Int                   @default(0)
  payload             Json
  errorMessage        String?               @map("error_message") @db.VarChar(2000)
  occurredAt          DateTime              @map("occurred_at")
  lastAttemptAt       DateTime?             @map("last_attempt_at")
  nextAttemptAt       DateTime              @default(now()) @map("next_attempt_at")
  processingStartedAt DateTime?             @map("processing_started_at")
  processedAt         DateTime?             @map("processed_at")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor       User?                  @relation("AutomationEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  runs        AutomationRun[]
  delayedRuns AutomationDelayedRun[]

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, status, nextAttemptAt])
  @@index([tenantId, status, occurredAt])
  @@index([tenantId, eventName, scopeType, scopeId])
  @@map("automation_events")
}

model AutomationRun {
  id                String                  @id @default(uuid()) @map("automation_run_id")
  tenantId          String                  @map("tenant_id")
  automationId      String                  @map("automation_definition_id")
  automationEventId String?                 @map("automation_event_id")
  status            AutomationRunStatus
  executionMode     AutomationExecutionMode @default(LIVE) @map("execution_mode")
  eventName         String                  @map("event_name") @db.VarChar(120)
  entityType        String                  @map("entity_type") @db.VarChar(100)
  entityId          String                  @map("entity_id")
  dedupeKey         String?                 @map("dedupe_key") @db.VarChar(255)
  actorUserId       String?                 @map("actor_user_id")
  triggerPayload    Json                    @map("trigger_payload")
  /// Phase 3: copy of `AutomationDefinition.flowGraph` at run start for resume (EC-12 / AT-RSU-004).
  flowGraphSnapshot Json?                   @map("flow_graph_snapshot")
  stepOutput        Json?                   @map("step_output")
  errorMessage      String?                 @map("error_message") @db.VarChar(2000)
  startedAt         DateTime                @default(now()) @map("started_at")
  completedAt       DateTime?               @map("completed_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automation AutomationDefinition @relation(fields: [automationId], references: [id], onDelete: Cascade)
  event      AutomationEvent?     @relation(fields: [automationEventId], references: [id], onDelete: SetNull)
  actor      User?                @relation("AutomationRunActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  runSteps   AutomationRunStep[]
  workItems  WorkItem[]
  transfers  Transfer[]

  @@unique([automationId, dedupeKey])
  @@index([tenantId, automationId, startedAt])
  @@index([automationId, status])
  @@map("automation_runs")
}

model AutomationRunStep {
  id               String              @id @default(uuid()) @map("automation_run_step_id")
  automationRunId  String              @map("automation_run_id")
  /// Null when this row records a graph `action` node (use graphNodeId).
  automationStepId String?             @map("automation_step_id")
  graphNodeId      String?             @map("graph_node_id") @db.VarChar(36)
  status           AutomationRunStatus
  output           Json?
  errorMessage     String?             @map("error_message") @db.VarChar(2000)
  startedAt        DateTime            @default(now()) @map("started_at")
  completedAt      DateTime?           @map("completed_at")

  run  AutomationRun   @relation(fields: [automationRunId], references: [id], onDelete: Cascade)
  step AutomationStep? @relation(fields: [automationStepId], references: [id], onDelete: Cascade)

  @@index([automationRunId])
  @@index([automationStepId])
  @@index([graphNodeId])
  @@map("automation_run_steps")
}

model AutomationDelayedRun {
  id                     String                     @id @default(uuid()) @map("automation_delayed_run_id")
  tenantId               String                     @map("tenant_id")
  automationEventId      String                     @map("automation_event_id")
  automationDefinitionId String                     @map("automation_definition_id")
  automationTriggerId    String                     @map("automation_trigger_id")
  fireAt                 DateTime                   @map("fire_at")
  status                 AutomationDelayedRunStatus @default(PENDING)
  errorMessage           String?                    @map("error_message") @db.VarChar(2000)
  createdAt              DateTime                   @default(now()) @map("created_at")
  processedAt            DateTime?                  @map("processed_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event      AutomationEvent      @relation(fields: [automationEventId], references: [id], onDelete: Cascade)
  automation AutomationDefinition @relation(fields: [automationDefinitionId], references: [id], onDelete: Cascade)
  trigger    AutomationTrigger    @relation(fields: [automationTriggerId], references: [id], onDelete: Cascade)

  @@unique([automationEventId, automationDefinitionId, automationTriggerId])
  @@index([tenantId, status, fireAt])
  @@map("automation_delayed_runs")
}

model WorkItem {
