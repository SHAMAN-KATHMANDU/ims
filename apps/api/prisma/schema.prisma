generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MODEL
// ============================================

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  productsCreated   Product[]     @relation("ProductCreator")
  transfersCreated  Transfer[]    @relation("TransferCreator")
  transfersApproved Transfer[]    @relation("TransferApprover")
  transferLogs      TransferLog[]
  salesCreated      Sale[]        @relation("SaleCreator")

  @@map("users")
}

enum Role {
  superAdmin
  admin
  user
}

// ============================================
// PRODUCT MODELS
// ============================================

model Category {
  id          String   @id @default(uuid()) @map("category_id")
  name        String   @unique @map("category_name") @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products      Product[]
  subCategories SubCategory[]

  @@map("categories")
}

model SubCategory {
  id         String   @id @default(uuid()) @map("sub_category_id")
  name       String   @db.VarChar(255)
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, name])
  @@map("sub_categories")
}

model Product {
  id           String   @id @default(uuid()) @map("product_id")
  imsCode      String   @unique @map("ims_code") @db.VarChar(100)
  name         String   @map("product_name") @db.VarChar(255)
  categoryId   String   @map("category_id")
  /// Optional sub-category label for further grouping within a category (denormalized name)
  subCategory  String?  @map("sub_category") @db.VarChar(255)
  /// Optional relation to sub-category entity
  subCategoryId String? @map("sub_category_id")
  description  String?  @db.Text
  length       Decimal? @db.Decimal(10, 2)
  breadth      Decimal? @db.Decimal(10, 2)
  height       Decimal? @db.Decimal(10, 2)
  weight       Decimal? @db.Decimal(10, 2)
  /// Base cost price (for margin analytics)
  costPrice    Decimal  @map("cost_price") @db.Decimal(10, 2)
  /// MRP / list price (before discounts)
  mrp          Decimal  @db.Decimal(10, 2)
  /// Default selling price used as the base for discount calculations
  finalSp      Decimal  @default(0) @map("final_sp") @db.Decimal(10, 2)
  /// Optional vendor this product is sourced from
  vendorId     String?  @map("vendor_id")
  createdById  String   @map("created_by_id")
  dateCreated  DateTime @default(now()) @map("date_created")
  dateModified DateTime @updatedAt @map("date_modified")

  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy    User         @relation("ProductCreator", fields: [createdById], references: [id], onDelete: Restrict)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  subCategoryRel SubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  variations   ProductVariation[]
  discounts    ProductDiscount[]
  promoCodes   PromoCodeProduct[]

  @@map("products")
}

model ProductVariation {
  id            String   @id @default(uuid()) @map("variation_id")
  productId     String   @map("product_id")
  /// Generic label for the variation (design / color / model)
  color         String   @db.VarChar(100)
  stockQuantity Int      @default(0) @map("stock_quantity")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  product           Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  subVariations     ProductSubVariation[]
  photos            VariationPhoto[]
  locationInventory LocationInventory[]
  transferItems     TransferItem[]
  saleItems         SaleItem[]

  @@unique([productId, color])
  @@map("product_variations")
}

model ProductSubVariation {
  id         String   @id @default(uuid()) @map("sub_variation_id")
  variationId String  @map("variation_id")
  name       String   @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  variation ProductVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)
  locationInventory LocationInventory[]
  transferItems     TransferItem[]
  saleItems         SaleItem[]

  @@unique([variationId, name])
  @@map("product_sub_variations")
}

model VariationPhoto {
  id          String   @id @default(uuid()) @map("photo_id")
  variationId String   @map("variation_id")
  photoUrl    String   @map("photo_url") @db.VarChar(500)
  isPrimary   Boolean  @default(false) @map("is_primary")
  uploadDate  DateTime @default(now()) @map("upload_date")

  variation ProductVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@map("variation_photos")
}

model DiscountType {
  id          String   @id @default(uuid()) @map("discount_type_id")
  name        String   @unique @map("type_name") @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  productDiscounts ProductDiscount[]

  @@map("discount_types")
}

/// How a discount or promo value should be interpreted
enum DiscountValueType {
  PERCENTAGE
  FLAT
}

model ProductDiscount {
  id                 String    @id @default(uuid()) @map("discount_id")
  productId          String    @map("product_id")
  discountTypeId     String    @map("discount_type_id")
  /// Legacy percentage field (kept for backwards compatibility)
  discountPercentage Decimal   @map("discount_percentage") @db.Decimal(5, 2)
  /// New flexible discount configuration
  valueType          DiscountValueType @default(PERCENTAGE) @map("value_type")
  /// When valueType = PERCENTAGE this is a percentage (0-100); when FLAT this is a currency amount
  value              Decimal           @default(0) @map("value") @db.Decimal(12, 2)
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountType DiscountType @relation(fields: [discountTypeId], references: [id], onDelete: Restrict)

  @@unique([productId, discountTypeId])
  @@map("product_discounts")
}

// ============================================
// VENDOR MODEL
// ============================================

model Vendor {
  id        String   @id @default(uuid()) @map("vendor_id")
  name      String   @unique @db.VarChar(255)
  contact   String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  address   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("vendors")
}

// ============================================
// LOCATION & INVENTORY MODELS
// ============================================

model Location {
  id                String       @id @default(uuid()) @map("location_id")
  name              String       @unique @map("location_name") @db.VarChar(255)
  type              LocationType @default(SHOWROOM)
  address           String?      @db.Text
  isActive          Boolean      @default(true) @map("is_active")
  /// When true, new product stock is added here by default; only one warehouse should be default
  isDefaultWarehouse Boolean     @default(false) @map("is_default_warehouse")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  inventory     LocationInventory[]
  transfersFrom Transfer[]          @relation("TransferFrom")
  transfersTo   Transfer[]          @relation("TransferTo")
  sales         Sale[]

  @@map("locations")
}

enum LocationType {
  WAREHOUSE
  SHOWROOM
}

model LocationInventory {
  id              String   @id @default(uuid()) @map("inventory_id")
  locationId      String   @map("location_id")
  variationId     String   @map("variation_id")
  subVariationId  String?  @map("sub_variation_id")
  quantity        Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  location    Location           @relation(fields: [locationId], references: [id], onDelete: Restrict)
  variation   ProductVariation   @relation(fields: [variationId], references: [id], onDelete: Cascade)
  subVariation ProductSubVariation? @relation(fields: [subVariationId], references: [id], onDelete: Cascade)

  @@unique([locationId, variationId, subVariationId])
  @@map("location_inventory")
}

// ============================================
// TRANSFER MODELS
// ============================================

model Transfer {
  id             String         @id @default(uuid()) @map("transfer_id")
  transferCode   String         @unique @map("transfer_code") @db.VarChar(50)
  fromLocationId String         @map("from_location_id")
  toLocationId   String         @map("to_location_id")
  status         TransferStatus @default(PENDING)
  notes          String?        @db.Text
  createdById    String         @map("created_by_id")
  approvedById   String?        @map("approved_by_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  approvedAt     DateTime?      @map("approved_at")
  completedAt    DateTime?      @map("completed_at")

  fromLocation Location       @relation("TransferFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   Location       @relation("TransferTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  createdBy    User           @relation("TransferCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy   User?          @relation("TransferApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  items        TransferItem[]
  logs         TransferLog[]

  @@map("transfers")
}

enum TransferStatus {
  PENDING
  APPROVED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model TransferItem {
  id              String  @id @default(uuid()) @map("transfer_item_id")
  transferId      String  @map("transfer_id")
  variationId     String  @map("variation_id")
  subVariationId  String? @map("sub_variation_id")
  quantity        Int

  transfer     Transfer           @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variation    ProductVariation   @relation(fields: [variationId], references: [id], onDelete: Restrict)
  subVariation ProductSubVariation? @relation(fields: [subVariationId], references: [id], onDelete: Restrict)

  @@unique([transferId, variationId, subVariationId])
  @@map("transfer_items")
}

model TransferLog {
  id         String   @id @default(uuid()) @map("log_id")
  transferId String   @map("transfer_id")
  action     String   @db.VarChar(50)
  details    Json?
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("transfer_logs")
}

// ============================================
// MEMBER & SALES MODELS
// ============================================

model Member {
  id        String   @id @default(uuid()) @map("member_id")
  phone     String   @unique @db.VarChar(20)
  name      String?  @db.VarChar(255)
  email     String?  @db.VarChar(255)
  notes     String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  gender    String?  @db.VarChar(20)
  age       Int?
  address   String?  @db.Text
  birthday  DateTime?
  /// Aggregated lifetime sales amount for this customer
  totalSales    Decimal?     @default(0) @map("total_sales") @db.Decimal(12, 2)
  /// Membership status (e.g. VIP, Active, etc.)
  memberStatus  MemberStatus @default(ACTIVE) @map("member_status")
  /// When the customer became a member
  memberSince   DateTime?    @map("member_since")
  /// First purchase date
  firstPurchase DateTime?    @map("first_purchase")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sales Sale[]

  @@map("members")
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  VIP
}

model Sale {
  id          String   @id @default(uuid()) @map("sale_id")
  saleCode    String   @unique @map("sale_code") @db.VarChar(50)
  type        SaleType @default(GENERAL)
  locationId  String   @map("location_id")
  memberId    String?  @map("member_id")
  subtotal    Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  notes       String?  @db.Text
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  location  Location   @relation(fields: [locationId], references: [id], onDelete: Restrict)
  member    Member?    @relation(fields: [memberId], references: [id], onDelete: Restrict)
  createdBy User       @relation("SaleCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items     SaleItem[]
  payments  SalePayment[]

  @@map("sales")
}

enum SaleType {
  GENERAL
  MEMBER
}

model SaleItem {
  id              String  @id @default(uuid()) @map("sale_item_id")
  saleId          String  @map("sale_id")
  variationId     String  @map("variation_id")
  subVariationId  String? @map("sub_variation_id")
  quantity        Int
  /// Snapshot of the MRP / unit price at the time of sale
  unitPrice       Decimal @db.Decimal(10, 2)
  /// Total MRP (unitPrice * quantity) at the time of sale
  totalMrp        Decimal @default(0) @map("total_mrp") @db.Decimal(12, 2)
  /// Percentage discount applied on this line (derived from product discounts & promo codes)
  discountPercent Decimal @default(0) @map("discount_percent") @db.Decimal(5, 2)
  /// Absolute discount value applied on this line
  discountAmount  Decimal @default(0) @map("discount_amount") @db.Decimal(12, 2)
  /// Final payable for this line after all discounts
  lineTotal       Decimal @map("line_total") @db.Decimal(12, 2)

  sale         Sale               @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variation    ProductVariation   @relation(fields: [variationId], references: [id], onDelete: Restrict)
  subVariation ProductSubVariation? @relation(fields: [subVariationId], references: [id], onDelete: Restrict)

  @@map("sale_items")
}

// ============================================
// PAYMENT & PROMO MODELS
// ============================================

enum PaymentMethod {
  CASH
  CARD
  CHEQUE
  FONEPAY
  QR
}

model SalePayment {
  id        String        @id @default(uuid()) @map("payment_id")
  saleId    String        @map("sale_id")
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  createdAt DateTime      @default(now()) @map("created_at")

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_payments")
}

enum PromoEligibility {
  ALL
  MEMBER
  NON_MEMBER
  WHOLESALE
}

model PromoCode {
  id                String             @id @default(uuid()) @map("promo_id")
  code              String             @unique @db.VarChar(50)
  description       String?            @db.Text
  valueType         DiscountValueType  @map("value_type")
  value             Decimal            @db.Decimal(12, 2)
  overrideDiscounts Boolean            @default(false) @map("override_discounts")
  allowStacking     Boolean            @default(false) @map("allow_stacking")
  eligibility       PromoEligibility   @default(ALL)
  validFrom         DateTime?          @map("valid_from")
  validTo           DateTime?          @map("valid_to")
  usageLimit        Int?               @map("usage_limit")
  usageCount        Int                @default(0) @map("usage_count")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  products PromoCodeProduct[]

  @@map("promo_codes")
}

model PromoCodeProduct {
  id          String    @id @default(uuid()) @map("promo_product_id")
  promoCodeId String    @map("promo_id")
  productId   String    @map("product_id")

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, productId])
  @@map("promo_code_products")
}
