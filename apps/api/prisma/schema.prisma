model WorkItemLink {
  id                String   @id @default(uuid()) @map("work_item_link_id")
  workItemId        String   @map("work_item_id")
  entityType        String   @map("entity_type") @db.VarChar(100)
  entityId          String   @map("entity_id")
  inventorySignalId String?  @map("inventory_signal_id")
  createdAt         DateTime @default(now()) @map("created_at")

  workItem        WorkItem         @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  inventorySignal InventorySignal? @relation(fields: [inventorySignalId], references: [id], onDelete: SetNull)

  @@index([workItemId])
  @@index([entityType, entityId])
  @@map("work_item_links")
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id                String     @id @default(uuid()) @map("deal_id")
  tenantId          String     @map("tenant_id")
  name              String     @map("deal_name") @db.VarChar(255)
  value             Decimal    @db.Decimal(12, 2)
  stage             String     @db.VarChar(100)
  probability       Int        @default(0) // 0-100
  status            DealStatus @default(OPEN)
  expectedCloseDate DateTime?  @map("expected_close_date")
  closedAt          DateTime?  @map("closed_at")
  lostReason        String?    @map("lost_reason") @db.VarChar(255)
  contactId         String?    @map("contact_id")
  memberId          String?    @map("member_id")
  companyId         String?    @map("company_id")
  pipelineId        String     @map("pipeline_id")
  assignedToId      String     @map("assigned_to_id")
  createdById       String     @map("created_by_id")
  leadId            String?    @unique @map("lead_id")
  deletedAt         DateTime?  @map("deleted_at")
  deletedBy         String?    @map("deleted_by")
  deleteReason      String?    @map("delete_reason") @db.VarChar(500)
  parentDealId      String?    @map("parent_deal_id")
  revisionNo        Int        @default(1) @map("revision_no")
  isLatest          Boolean    @default(true) @map("is_latest")
  editReason        String?    @map("edit_reason") @db.VarChar(500)
  editedById        String?    @map("edited_by_id")
  editedAt          DateTime?  @map("edited_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact              Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  member               Member?               @relation("DealMember", fields: [memberId], references: [id], onDelete: SetNull)
  company              Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  pipeline             Pipeline              @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  assignedTo           User                  @relation("DealAssignedTo", fields: [assignedToId], references: [id], onDelete: Restrict)
  creator              User                  @relation("DealCreator", fields: [createdById], references: [id], onDelete: Restrict)
  editedBy             User?                 @relation("DealEditedBy", fields: [editedById], references: [id], onDelete: SetNull)
  lead                 Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  parentDeal           Deal?                 @relation("DealRevisions", fields: [parentDealId], references: [id], onDelete: SetNull)
  revisions            Deal[]                @relation("DealRevisions")
  tasks                Task[]
  activities           Activity[]
  lineItems            DealLineItem[]
  remarketingSequences RemarketingSequence[]

  @@index([tenantId])
  @@index([parentDealId])
  @@index([isLatest])
  @@map("deals")
}

model DealLineItem {
  id          String            @id @default(uuid()) @map("deal_line_item_id")
  dealId      String            @map("deal_id")
  productId   String            @map("product_id")
  variationId String?           @map("variation_id")
  quantity    Int               @default(1)
  unitPrice   Decimal           @default(0) @map("unit_price") @db.Decimal(12, 2)
  deal        Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product     Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  variation   ProductVariation? @relation(fields: [variationId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@map("deal_line_items")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskWorkflowStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

model Task {
  id           String             @id @default(uuid()) @map("task_id")
  tenantId     String             @map("tenant_id")
  title        String             @db.VarChar(500)
  dueDate      DateTime?          @map("due_date")
  completed    Boolean            @default(false)
  status       TaskWorkflowStatus @default(OPEN) @map("workflow_status")
  priority     TaskPriority       @default(MEDIUM)
  contactId    String?            @map("contact_id")
  memberId     String?            @map("member_id")
  dealId       String?            @map("deal_id")
  companyId    String?            @map("company_id")
  assignedToId String             @map("assigned_to_id")
  deletedAt    DateTime?          @map("deleted_at")
  deletedBy    String?            @map("deleted_by")
  deleteReason String?            @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  member     Member?  @relation("TaskMember", fields: [memberId], references: [id], onDelete: SetNull)
  deal       Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  company    Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedTo User     @relation(fields: [assignedToId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([companyId])
  @@map("tasks")
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
}

model Activity {
  id           String       @id @default(uuid()) @map("activity_id")
  tenantId     String       @map("tenant_id")
  type         ActivityType
  subject      String?      @db.VarChar(500)
  notes        String?      @db.Text
  activityAt   DateTime     @map("activity_at")
  contactId    String?      @map("contact_id")
  memberId     String?      @map("member_id")
  dealId       String?      @map("deal_id")
  createdById  String       @map("created_by_id")
  deletedAt    DateTime?    @map("deleted_at")
  deletedBy    String?      @map("deleted_by")
  deleteReason String?      @map("delete_reason") @db.VarChar(500)
  createdAt    DateTime     @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  member  Member?  @relation("ActivityMember", fields: [memberId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  creator User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("activities")
}

model CrmSource {
  id        String   @id @default(uuid()) @map("crm_source_id")
  tenantId  String   @map("tenant_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("crm_sources")
}

model CrmJourneyType {
  id        String   @id @default(uuid()) @map("crm_journey_type_id")
  tenantId  String   @map("tenant_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("crm_journey_types")
}

enum NotificationType {
  TASK_DUE
  DEAL_STAGE_CHANGE
  LEAD_ASSIGNMENT
  NEW_MESSAGE
}

model Notification {
  id           String           @id @default(uuid()) @map("notification_id")
  userId       String           @map("user_id")
  type         NotificationType
  title        String           @map("title") @db.VarChar(255)
  message      String?          @db.Text
  resourceType String?          @map("resource_type") @db.VarChar(50)
  resourceId   String?          @map("resource_id") @db.VarChar(100)
  readAt       DateTime?        @map("read_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================
// REMARKETING SEQUENCE (timed nurture)
// ============================================

enum SequenceStatus {
  PENDING
  EXECUTED
  SKIPPED
  PAUSED
}

model RemarketingSequence {
  id          String         @id @default(uuid()) @map("sequence_id")
  tenantId    String         @map("tenant_id")
  contactId   String         @map("contact_id")
  dealId      String?        @map("deal_id")
  sequenceDay Int            @map("sequence_day")
  message     String?        @db.Text
  scheduledAt DateTime       @map("scheduled_at")
  executedAt  DateTime?      @map("executed_at")
  status      SequenceStatus @default(PENDING)
  createdAt   DateTime       @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal    Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status, scheduledAt])
  @@map("remarketing_sequences")
}

// ============================================
// MESSAGING SYSTEM
// ============================================

enum MessagingProvider {
  FACEBOOK_MESSENGER
}

enum ChannelStatus {
  PENDING
  ACTIVE
  DISCONNECTED
  ERROR
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageContentType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  LOCATION
  POSTBACK
  STICKER
}

/// A tenant's connected messaging channel (e.g., a Facebook Page).
model MessagingChannel {
  id       String            @id @default(uuid()) @map("channel_id")
  tenantId String            @map("tenant_id")
  provider MessagingProvider
  name     String            @db.VarChar(255)
  status   ChannelStatus     @default(PENDING)

  /// Facebook Page ID — used for inbound routing. Null until manual setup step 2 (after webhook verify).
  externalId String? @map("external_id") @db.VarChar(255)

  /// Encrypted per-channel credentials (JSON, encrypted at rest).
  /// Facebook: { pageAccessToken: "..." }. Null until credentials are supplied.
  credentialsEnc String? @map("credentials_enc") @db.Text

  /// Meta GET verification; must be unique when set so webhook challenge resolves the right row.
  webhookVerifyToken String? @unique @map("webhook_verify_token") @db.VarChar(255)

  /// Non-sensitive provider metadata (page name, category, URL).
  metadata Json?

  connectedAt    DateTime? @map("connected_at")
  disconnectedAt DateTime? @map("disconnected_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([provider, externalId])
  @@index([tenantId])
  @@index([externalId])
  @@map("messaging_channels")
}

/// A conversation thread between a tenant (via a channel) and an external participant.
model Conversation {
  id        String @id @default(uuid()) @map("conversation_id")
  tenantId  String @map("tenant_id")
  channelId String @map("channel_id")

  /// Page-scoped User ID (PSID) for Facebook Messenger.
  participantId String @map("participant_id") @db.VarChar(255)

  /// Resolved display name of the external participant.
  participantName String? @map("participant_name") @db.VarChar(255)

  /// Profile picture URL from the messaging provider (e.g. Facebook Graph API).
  participantProfilePictureUrl String? @map("participant_profile_picture_url") @db.Text

  /// Link to IMS Contact (auto-matched or manually linked).
  contactId String? @map("contact_id")

  status ConversationStatus @default(OPEN)

  /// User currently assigned to handle this conversation.
  assignedToId String? @map("assigned_to_id")

  /// Timestamp of the last message (for sorting).
  lastMessageAt DateTime? @map("last_message_at")

  /// Snippet of the last message for list views.
  lastMessageText String? @map("last_message_text") @db.VarChar(500)

  /// Count of unread inbound messages.
  unreadCount Int @default(0) @map("unread_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel    MessagingChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  contact    Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo User?            @relation("ConversationAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   Message[]

  @@unique([channelId, participantId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([lastMessageAt])
  @@map("conversations")
}

/// Individual message within a conversation.
model Message {
  id             String             @id @default(uuid()) @map("message_id")
  conversationId String             @map("conversation_id")
  direction      MessageDirection
  status         MessageStatus      @default(PENDING)
  contentType    MessageContentType @default(TEXT) @map("content_type")

  /// Text content (or caption for media messages).
  textContent String? @map("text_content") @db.Text

  /// Structured media/payload content (provider-agnostic JSON).
  mediaPayload Json?   @map("media_payload")
  /// Dashboard-uploaded media registered in the tenant media library.
  mediaAssetId String? @map("media_asset_id")

  /// Provider's message ID for deduplication and status tracking.
  providerMessageId String? @map("provider_message_id") @db.VarChar(255)

  /// ID of the IMS user who sent this outbound message (null for inbound).
  sentById String? @map("sent_by_id")

  /// Error details if sending failed.
  errorDetails Json? @map("error_details")

  /// Timestamps for delivery tracking.
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  /// When set, this message was edited in the inbox UI.
  editedAt DateTime? @map("edited_at")

  /// Optional reply reference (same conversation).
  replyToId String? @map("reply_to_id")

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy       User?             @relation("MessageSender", fields: [sentById], references: [id], onDelete: SetNull)
  replyTo      Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]         @relation("MessageReplies")
  reactions    MessageReaction[]
  mediaAsset   MediaAsset?       @relation(fields: [mediaAssetId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
  @@index([mediaAssetId])
  @@index([providerMessageId])
  @@index([replyToId])
  @@map("messages")
}

/// Emoji reaction on a message (dashboard user and/or external Messenger participant).
model MessageReaction {
  id                    String   @id @default(uuid()) @map("reaction_id")
  messageId             String   @map("message_id")
  /// Set when the reaction was added from the tenant dashboard API.
  userId                String?  @map("user_id")
  /// Set when the reaction came from a Messenger webhook (PSID).
  externalParticipantId String?  @map("external_participant_id") @db.VarChar(255)
  /// Stable reactor identity: `u:<userId>` or `e:<externalParticipantId>`.
  reactionOwnerKey      String   @map("reaction_owner_key") @db.VarChar(200)
  emoji                 String   @db.VarChar(32)
  createdAt             DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User?   @relation("MessageReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, emoji, reactionOwnerKey])
  @@index([messageId])
  @@map("message_reactions")
}

/// Idempotency tracking for inbound webhook events.
model WebhookEvent {
  id String @id @default(uuid()) @map("event_id")

  /// Provider-assigned event/message ID for deduplication.
  providerEventId String @unique @map("provider_event_id") @db.VarChar(255)

  provider    MessagingProvider
  eventType   String            @db.VarChar(100)
  processedAt DateTime          @default(now()) @map("processed_at")

  /// Raw event payload for debugging/replay.
  rawPayload Json? @map("raw_payload")

  @@index([providerEventId])
  @@map("webhook_events")
}
