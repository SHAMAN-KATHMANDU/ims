# PostgreSQL Docker Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=projectx
POSTGRES_PORT=5432

# Database Connection URL (for Prisma)
# Use localhost when running API locally (e.g. nodemon); use postgres only when API runs inside Docker.
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/projectx?schema=public&connection_limit=20&pool_timeout=30

# SuperAdmin Credentials (for seeding)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=your_superadmin_password

# Server Configuration
PORT=4000
HOST=0.0.0.0

# Authentication
JWT_SECRET=your_jwt_secret_key
JWT_ACCESS_EXPIRES_IN=4h
JWT_REFRESH_TTL_DAYS=7

# Environment
NODE_ENV=development

# Web Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1