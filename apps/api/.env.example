# PostgreSQL Docker Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=projectx
POSTGRES_PORT=5432

# Database Connection URL (for Prisma)
# Use localhost when running API locally (e.g. nodemon); use postgres only when API runs inside Docker.
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/projectx?schema=public

# SuperAdmin Credentials (for seeding)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=your_superadmin_password

# Server Configuration
PORT=4000
HOST=0.0.0.0

# Authentication
JWT_SECRET=your_jwt_secret_key
# Optional in dev (falls back to JWT_SECRET); REQUIRED in staging/prod.
# Use a different value than JWT_SECRET so an access token cannot be replayed
# at /auth/refresh and vice versa.
JWT_REFRESH_SECRET=your_refresh_jwt_secret_key
# Token lifetimes — short access, long refresh. Refresh-token rotation on every
# /auth/refresh call gives leaked tokens a bounded window.
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=30d

# Environment
NODE_ENV=development

# Web Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Public API URL — base used for Swagger and for building absolute /uploads/... links.
# Must end with /api/v1 if that is your API mount path (value is stripped to get the server origin for static files).
#
# Facebook Messenger outbound images/videos: Meta's servers download the file from this host.
# Use a publicly reachable HTTPS URL in staging/production (e.g. https://api.yourdomain.com/api/v1).
# localhost/127.0.0.1 works for the web app previewing media but Meta cannot fetch from it — image sends will fail until the API is exposed.
API_PUBLIC_URL=http://localhost:4000/api/v1

# Redis (required for messaging queues and real-time)
REDIS_URL=redis://localhost:6379

# Facebook Messenger Integration
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# AI messaging auto-replies (Google Gemini by default — key from Google AI Studio)
# Without AI_REPLY_API_KEY, auto-reply is skipped (logged only).
AI_REPLY_PROVIDER=GEMINI_API
AI_REPLY_API_KEY=
AI_REPLY_MODEL=gemini-2.5-flash
# Optional override; default is https://generativelanguage.googleapis.com/v1beta
# AI_REPLY_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# When true, new tenants get AI replies on by default unless overridden per channel.
# AI_REPLY_ENABLED_DEFAULT=false

# Braintrust (optional — evals / logging for AI replies)
# BRAINTRUST_API_KEY=
# BRAINTRUST_PROJECT_NAME=IMS AI Replies

# Credential Encryption (32-byte hex key for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# S3 tenant media (optional in development — presign disabled if unset)
# Use IAM role on EC2 in production; or AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY locally.
AWS_REGION=ap-south-1
PHOTOS_S3_BUCKET=ims-shaman-photos
PHOTOS_PUBLIC_URL_PREFIX=https://ims-shaman-photos.s3.ap-south-1.amazonaws.com/
# Optional: comma-separated alias prefixes (e.g. CloudFront) so clients may send a matching publicUrl on register (server URL is always canonical primary).
# PHOTOS_PUBLIC_URL_ALIASES=https://d111111abcdef8.cloudfront.net/
# Object key prefix: dev | stage | prod (isolates environments in the shared bucket).
# Required in staging/production when PHOTOS_S3_BUCKET is set; in development defaults to dev if unset.
PHOTOS_S3_KEY_PREFIX=dev
# HeadBucket on startup when S3 is configured (default on in staging/prod; set 0 to skip).
# PHOTOS_S3_VERIFY_ON_STARTUP=1
# Migration: accept legacy keys without env prefix (tenants/{tenantId}/...) for validation only.
# PHOTOS_ALLOW_LEGACY_KEYS=0
# Optional: verify first bytes on register vs declared MIME (adds S3 read latency).
# PHOTOS_ENFORCE_CONTENT_SNIFF=0
# Optional human label for runbooks (not required by the API).
# IMS_DEPLOYMENT_TIER=prod
