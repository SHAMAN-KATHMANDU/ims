# PostgreSQL Docker Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=projectx
POSTGRES_PORT=5432

# Database Connection URL (for Prisma)
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/projectx?schema=public

# SuperAdmin Credentials (for seeding)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=your_superadmin_password

# API Configuration
JWT_SECRET=your_jwt_secret_key
PORT=4000

# Web Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
