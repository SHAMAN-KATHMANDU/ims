# API Production Environment Variables
# Copy to .env when running the API in staging or production.

# Required in non-dev (app will exit if missing)
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/ims?schema=public&connection_limit=20&pool_timeout=30
JWT_SECRET=your-super-secret-jwt-key-for-production
CORS_ORIGIN=https://your-frontend-domain.com
API_PUBLIC_URL=https://your-api-domain.com/api/v1

# Server (optional; defaults shown)
PORT=4000
HOST=0.0.0.0

# SuperAdmin (for seed only)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=your_superadmin_password

# Environment
NODE_ENV=production
