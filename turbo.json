{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^prisma:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "DOCKER_ENV",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_DSN",
        "SENTRY_TRACES_SAMPLE_RATE",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE"
      ]
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [],
      "env": [
        "CI",
        "PLAYWRIGHT_BASE_URL",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_DSN",
        "SENTRY_TRACES_SAMPLE_RATE",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE"
      ]
    },
    "prisma:generate": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "prisma:migrate": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "prisma:migrate:deploy": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "prisma:studio": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "prisma:seed": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "prisma:reset": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "check-types": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [],
      "env": ["CI", "PLAYWRIGHT_BASE_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "NEXT_PUBLIC_API_URL"]
    }
  }
}
