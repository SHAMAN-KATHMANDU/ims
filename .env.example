# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ims

# Database URL (used by Prisma)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ims

# API
PORT=4000
HOST=0.0.0.0
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Optional: comma-separated hostnames for next/image (S3/CDN) when not using the default bucket host
# NEXT_PUBLIC_IMAGE_REMOTE_HOSTNAMES=my-bucket.s3.us-east-1.amazonaws.com,cdn.example.com

# API — S3 direct uploads (see apps/api/.env.example)
# AWS_REGION=ap-south-1
# PHOTOS_S3_BUCKET=ims-shaman-photos
# PHOTOS_PUBLIC_URL_PREFIX=https://ims-shaman-photos.s3.ap-south-1.amazonaws.com/
# PHOTOS_S3_KEY_PREFIX=dev

# Seed (prisma:seed) - tenant Ruby + platform admin
SEED_PLATFORM_ADMIN_USERNAME=platform
SEED_PLATFORM_ADMIN_PASSWORD=iIVkwg8Xllq
