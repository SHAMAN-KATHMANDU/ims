{
  "name": "@repo/shared",
  "version": "1.0.0",
  "description": "Shared utilities and types for the monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./blocks": {
      "types": "./dist/src/blocks/index.d.ts",
      "require": "./dist/src/blocks/index.js",
      "import": "./dist/src/blocks/index.js",
      "default": "./dist/src/blocks/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "luxon": "^3.7.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/luxon": "^3.7.1",
    "nodemon": "^3.1.11",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  }
}
