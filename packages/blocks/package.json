{
  "name": "@repo/blocks",
  "version": "1.0.0",
  "description": "Shared block rendering library for site builder canvas and production tenant sites",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./preview": {
      "types": "./src/preview-fixtures.ts",
      "default": "./src/preview-fixtures.ts"
    }
  },
  "scripts": {
    "build": "tsc || true",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "luxon": "^3.7.2",
    "next": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
