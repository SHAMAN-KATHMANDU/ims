# Production Environment Variables
# Copy this file to .env on your production server

# Docker Hub
DOCKERHUB_USERNAME=your-dockerhub-username

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=ims

# API
JWT_SECRET=your-super-secret-jwt-key-for-production
PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:your-secure-password-here@postgres:5432/ims
CORS_ORIGIN=https://your-frontend-domain.com
API_PUBLIC_URL=https://your-api-domain.com/api/v1

# Web
NEXT_PUBLIC_API_URL=http://your-domain.com:4000
